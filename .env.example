# Required
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Admin user (receives /stats and /uptime commands)
TELEGRAM_USER_ALIAS=your_telegram_username

# Database - SQLite (default)
SQLITE_FILE=/data/db.sqlite

# Database - MySQL (optional, overrides SQLite if set)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=rajoybot
# MYSQL_PASSWORD=rajoybot
# MYSQL_DATABASE=rajoybot

# Sound metadata
DATA_JSON=/app/data.json

# Logging
# LOGFILE=/data/rajoybot.log

# Webhook (optional, uses polling if not set)
# WEBHOOK_HOST=your.domain.com
# WEBHOOK_PORT=443
# WEBHOOK_LISTEN=0.0.0.0
# WEBHOOK_LISTEN_PORT=8080
